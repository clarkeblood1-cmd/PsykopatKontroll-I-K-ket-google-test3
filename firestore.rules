rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function householdExists(householdId) {
      return exists(/databases/$(database)/documents/households/$(householdId));
    }

    function isHouseholdMember(householdId) {
      return signedIn() &&
        householdExists(householdId) &&
        request.auth.uid in householdDoc(householdId).data.memberUids;
    }

    function isHouseholdOwner(householdId) {
      return isHouseholdMember(householdId) &&
        householdDoc(householdId).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids;

      allow read: if isHouseholdMember(householdId);
      allow update: if isHouseholdMember(householdId);
      allow delete: if isHouseholdOwner(householdId);
    }

    match /inviteCodes/{code} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isHouseholdMember(request.resource.data.householdId);

      allow read: if signedIn();

      allow update, delete: if signedIn() && (
        resource.data.createdBy == request.auth.uid ||
        isHouseholdOwner(resource.data.householdId)
      );
    }

    match /households/{householdId}/items/{itemId} {
      allow read, write: if isHouseholdMember(householdId);
    }

    match /households/{householdId}/logs/{logId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isHouseholdMember(householdId);
      allow update, delete: if false;
    }
  }
}
