rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isOwner(householdId) {
      return isHouseholdMember(householdId) &&
        get(/databases/$(database)/documents/households/$(householdId)).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if isMe(userId);
      allow delete: if false;
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isHouseholdMember(householdId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isSignedIn()
          && memberId == request.auth.uid
          && request.resource.data.uid == request.auth.uid;
        allow update: if isOwner(householdId) || isMe(memberId);
        allow delete: if isOwner(householdId) || isMe(memberId);
      }

      match /state/{docId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
