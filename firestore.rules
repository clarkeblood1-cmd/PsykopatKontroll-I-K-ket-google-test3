rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isMember(householdId) {
      return signedIn() && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isOwner(householdId) {
      return isMember(householdId)
        && get(/databases/$(database)/documents/households/$(householdId)).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /households/{householdId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isMember(householdId);
      allow update: if isMember(householdId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isMember(householdId);
        allow create: if signedIn() && memberId == request.auth.uid;
        allow update: if isOwner(householdId) || isSelf(memberId);
        allow delete: if isOwner(householdId) || isSelf(memberId);
      }

      match /state/{docId} {
        allow read, write: if isMember(householdId);
      }
    }
  }
}
