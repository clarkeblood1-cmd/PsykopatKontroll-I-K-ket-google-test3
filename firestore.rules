rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function activeHouseholdId() {
      return isSignedIn() && userDoc(request.auth.uid).data.activeHouseholdId is string
        ? userDoc(request.auth.uid).data.activeHouseholdId
        : '';
    }

    function isHouseholdMember(householdId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isHouseholdOwner(householdId) {
      return isHouseholdMember(householdId)
        && householdDoc(householdId).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isMe(userId);
      allow create: if isMe(userId);
      allow update: if isMe(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.activeHouseholdId is string;
      allow delete: if false;
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isHouseholdOwner(householdId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isSignedIn()
          && memberId == request.resource.data.uid
          && (isHouseholdOwner(householdId) || memberId == request.auth.uid)
          && activeHouseholdId() == householdId;
        allow update: if isHouseholdOwner(householdId)
          || (isMe(memberId)
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.role == resource.data.role);
        allow delete: if isHouseholdOwner(householdId) || isMe(memberId);
      }

      match /state/{docId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
