rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    match /households/{householdId}/images/{allPaths=**} {
      allow read, write: if isHouseholdMember(householdId);
    }

    match /users/{userId}/images/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
