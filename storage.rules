rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/images/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/item-images/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/auto-images/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /shared-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /auto-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /households/{householdId}/images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /households/{householdId}/item-images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /households/{householdId}/auto-images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
